---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorldClock from '../../components/ui/WorldClock.astro';
import RadioPlayer from '../../components/ui/RadioPlayer.astro';

const projects = await getCollection('work');
---

<BaseLayout title="Work — Antariksha Kumar" description="Case studies and selected projects by Antariksha Kumar — UX Engineer and Creative Technologist.">

  <!-- LIGHT SECTION — editorial header -->
  <section class="bg-offwhite px-4 pb-16 pt-28 md:px-8">
    <div class="relative mx-auto w-full max-w-7xl">

      <!-- Ghost watermark — hidden at xl where widgets occupy the same corner -->
      <span class="pointer-events-none absolute right-0 top-0 z-0 select-none font-necto text-[clamp(8rem,20vw,18rem)] leading-none text-black/[0.04] xl:hidden">
        {projects.length.toString().padStart(2, '0')}
      </span>

      <!-- Camera sketch — line art, white bg dissolved via multiply blend -->
      <img
        src="/camera%20sketch.jpg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute bottom-0 right-0 z-[1] w-[580px] select-none object-contain opacity-[0.10] mix-blend-multiply -rotate-6 xl:right-[268px]"
      />

      <!-- Widget panel — only xl+ where right-side space is available -->
      <div class="absolute right-0 top-0 z-20 hidden w-[248px] flex-col gap-4 xl:flex">
        <WorldClock />
        <RadioPlayer />
      </div>

      <!-- Main content -->
      <div class="relative z-10">
        <div class="mb-10 flex items-center justify-between border-b border-black/15 pb-4">
          <span class="font-montserrat text-[0.65rem] uppercase tracking-[0.25em] text-black/55">/ Work</span>
          <span class="font-necto text-[0.65rem] text-black/45 xl:hidden">{projects.length.toString().padStart(2, '0')} Projects</span>
        </div>
        <h1 class="font-necto text-[clamp(4rem,12vw,10rem)] uppercase leading-[0.85] text-black [word-spacing:-0.18em]">
          The Book<br />Of Deeds.
        </h1>
        <p class="mt-6 max-w-[52ch] text-[1.05rem] leading-[1.75] text-black/60">
          A collection of UX engineering and creative technology projects — from AI-powered tools
          to AR experiences and editorial interfaces.
        </p>
      </div>

    </div>
  </section>

  <!-- EDITORIAL LIST — project rows -->
  <section class="bg-offwhite px-4 pb-20 md:px-8">
    <div class="mx-auto w-full max-w-7xl">
      <div class="border-b border-black/20">
        {projects.map(({ id, data }) => (
          <a
            href={`/work/${id}`}
            class="group relative flex items-center gap-5 border-t border-black/20 py-6 transition-colors duration-200 hover:border-black/40"
            data-cursor-hover
          >
            {/* Teal left accent bar — scales down from top on hover */}
            <span
              class="absolute left-0 top-0 h-full w-0.5 origin-top scale-y-0 bg-teal transition-transform duration-300 group-hover:scale-y-100"
              aria-hidden="true"
            />

            {/* Image panel — slides in on hover */}
            <div class="relative hidden h-[72px] w-0 flex-shrink-0 overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:w-[108px] md:block">
              <img
                src={data.coverImage}
                alt={data.title}
                class="absolute inset-0 h-full w-full object-cover"
              />
            </div>

            {/* Serial number */}
            <span class="w-[88px] flex-shrink-0 font-necto text-[0.68rem] uppercase tracking-[0.15em] text-teal">
              {data.serialNumber}
            </span>

            {/* Title */}
            <h2 class="min-w-0 flex-1 font-necto text-[1.35rem] uppercase leading-[1] text-black md:text-[1.65rem]">
              {data.title}
            </h2>

            {/* Role — lg+ only */}
            <p class="hidden w-[210px] flex-shrink-0 font-montserrat text-[0.68rem] uppercase tracking-[0.18em] text-black/65 lg:block">
              {data.role}
            </p>

            {/* Year + Status */}
            <div class="flex flex-col items-end flex-shrink-0 gap-1">
              <p class="font-necto text-[0.68rem] text-black/60">{data.year}</p>
              {data.status === 'Live' && (
                <span class="bg-teal px-2 py-0.5 font-necto text-[0.58rem] uppercase tracking-[0.12em] text-white">
                  Live
                </span>
              )}
              {data.status === 'In Progress' && (
                <span class="inline-block border border-red px-1.5 py-0.5 font-necto text-[0.58rem] uppercase tracking-[0.1em] text-red">
                  In Progress
                </span>
              )}
              {data.status === 'Complete' && (
                <span class="font-necto text-[0.62rem] uppercase tracking-[0.12em] text-black/50">Complete</span>
              )}
            </div>

            {/* Tags — xl+ only */}
            <div class="hidden flex-shrink-0 gap-1.5 xl:flex">
              {data.tags.map((tag) => (
                <span class="bg-black px-2 py-0.5 font-montserrat text-[0.58rem] uppercase tracking-[0.12em] text-offwhite">
                  {tag}
                </span>
              ))}
            </div>

            {/* CTA arrow */}
            <span class="ml-auto flex-shrink-0 font-montserrat text-[0.7rem] uppercase tracking-[0.2em] text-teal transition-transform duration-300 group-hover:translate-x-1">
              →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
