---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = await getCollection('work');
---

<BaseLayout title="Work — Antariksha Kumar" description="Case studies and selected projects by Antariksha Kumar — UX Engineer and Creative Technologist.">

  <!-- LIGHT SECTION — editorial header -->
  <section class="bg-offwhite px-4 pb-16 pt-28 md:px-8">
    <div class="relative mx-auto w-full max-w-7xl">
      <span class="pointer-events-none absolute right-0 top-0 z-0 select-none font-necto text-[clamp(8rem,20vw,18rem)] leading-none text-black/[0.04]">
        {projects.length.toString().padStart(2, '0')}
      </span>
      <div class="relative z-10">
        <div class="mb-10 flex items-center justify-between border-b border-black/15 pb-4">
          <span class="font-montserrat text-[0.65rem] uppercase tracking-[0.25em] text-black/40">/ Work</span>
          <span class="font-necto text-[0.65rem] text-black/30">{projects.length.toString().padStart(2, '0')} Projects</span>
        </div>
        <h1 class="font-necto text-[clamp(4rem,12vw,10rem)] uppercase leading-[0.85] text-black">
          Selected<br />Work.
        </h1>
        <p class="mt-6 max-w-[52ch] text-[1.05rem] leading-[1.75] text-black/60">
          A collection of UX engineering and creative technology projects — from AI-powered tools
          to AR experiences and editorial interfaces.
        </p>
      </div>
    </div>
  </section>

  <!-- DARK SECTION — project grid -->
  <section class="bg-black px-4 pb-20 pt-12 md:px-8">
    <div class="mx-auto w-full max-w-7xl">
      <div class="grid gap-4 md:grid-cols-2">
        {projects.map(({ id, data }) => (
          <article class="border border-grey bg-surface p-5 transition-colors hover:border-teal-dim">
            <p class="font-necto text-[0.7rem] uppercase tracking-[0.2em] text-teal">{data.serialNumber}</p>
            <h2 class="mt-3 font-necto text-[2rem] uppercase leading-[1]">{data.title}</h2>
            <p class="mt-2 text-[1rem] leading-[1.6] text-offwhite/80">{data.description}</p>
            <p class="mt-3 font-montserrat text-[0.7rem] uppercase tracking-[0.2em] text-offwhite/50">{data.role} · {data.year}</p>
            {data.status === 'In Progress' && (
              <span class="mt-3 inline-block border border-red px-2 py-1 font-necto text-[0.65rem] uppercase tracking-[0.16em] text-red">
                In Progress
              </span>
            )}
            <a class="mt-4 inline-block font-montserrat text-[0.7rem] uppercase tracking-[0.2em] text-teal transition-colors hover:text-offwhite" href={`/work/${id}`} data-cursor-hover>
              Open Case Study →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

