---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).toUpperCase();
}

function padIndex(i: number): string {
  return String(i + 1).padStart(2, '0');
}

function padCount(n: number): string {
  return String(n).padStart(2, '0');
}
---

<BaseLayout title="Blog — Antariksha Kumar" description="Writing on design, code, and interactive storytelling.">
  <!-- Blog page — single offwhite section to prevent body-bg bleed -->
  <section class="bg-offwhite px-4 pt-28 pb-20 md:px-8">
    <div class="mx-auto w-full max-w-5xl relative">
      <!-- Ghost numeral -->
      <span class="font-necto text-[clamp(8rem,22vw,20rem)] leading-none text-black/[0.04] pointer-events-none select-none absolute right-0 top-0 z-0" aria-hidden="true">
        {padCount(posts.length)}
      </span>

      <!-- Visible content -->
      <div class="relative z-10">
        <!-- Top metadata strip -->
        <div class="flex items-center justify-between border-b border-black/15 pb-3 mb-10">
          <span class="font-necto text-[0.65rem] uppercase tracking-[0.25em] text-black/40">Writing</span>
          <span class="font-necto text-[0.65rem] uppercase tracking-[0.25em] text-black/40">Series: Design + Code</span>
          <span class="font-necto text-[0.65rem] uppercase tracking-[0.25em] text-black/40">{posts.length} Issues</span>
          <span class="font-necto text-[0.65rem] uppercase tracking-[0.25em] text-black/40">2025</span>
        </div>

        <!-- Display headline -->
        <h1 class="font-necto text-[clamp(4rem,12vw,10rem)] uppercase leading-[0.85] text-black [word-spacing:-0.18em]">
          The Red<br />Book.
        </h1>

        <!-- Subline -->
        <p class="font-serif text-[1.1rem] text-black/60 mt-4 max-w-[50ch]">
          On UX engineering, creative technology, and the intersection of code and craft.
        </p>
      </div>
    </div>

    <!-- Post listing -->
    <div class="mx-auto w-full max-w-5xl mt-16">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class="flex items-start justify-between gap-8 border-b border-black/10 py-6 group hover:border-black/30 transition-colors"
          data-cursor-hover
        >
          <!-- Left side -->
          <div class="flex-1">
            <p class="font-necto text-[0.7rem] text-black/30 mb-2">{padIndex(i)}</p>
            <h2 class="font-serif text-[1.6rem] leading-[1.1] text-black group-hover:text-black">
              {post.data.title}
            </h2>
            <p class="font-serif mt-2 text-[0.9rem] leading-[1.6] text-black/60 max-w-[55ch]">
              {post.data.excerpt}
            </p>
          </div>

          <!-- Right side -->
          <div class="shrink-0 text-right">
            <p class="font-necto text-[0.65rem] uppercase tracking-[0.18em] text-black/40">
              {formatDate(post.data.date)}
            </p>
            <p class="font-necto text-[0.65rem] uppercase tracking-[0.18em] text-black/40">
              {post.data.readTime}
            </p>
            {post.data.tags && post.data.tags.length > 0 && (
              <p class="font-montserrat text-[0.62rem] uppercase tracking-[0.18em] text-black/30 mt-1">
                {post.data.tags.join(', ')}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
