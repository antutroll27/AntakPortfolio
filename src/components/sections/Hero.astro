---
import GhostScene from "../three/GhostScene.astro";
import Button from "../ui/Button.astro";
---

<section
  class="hero-grain relative isolate min-h-[100dvh] overflow-hidden border-b border-grey"
  id="top"
>
  <GhostScene />

  <div
    class="relative z-10 mx-auto flex min-h-[100dvh] w-full max-w-7xl flex-col justify-center px-4 pb-16 pt-24 md:px-8 lg:pt-32"
  >
    <h1
      class="mt-4 font-necto text-5xl md:text-7xl lg:text-[7rem] uppercase leading-[0.9] text-offwhite"
    >
      <span class="hero-line block [clip-path:inset(100%_0_0_0)]"
        >Bridging Design,</span
      >
      <span class="hero-line block [clip-path:inset(100%_0_0_0)]"
        >Tech & Cinematography</span
      >
      <span class="hero-line block [clip-path:inset(100%_0_0_0)]"
        >Between Design And Code.</span
      >
    </h1>

    <p
      class="hero-copy mt-8 max-w-3xl text-[1.125rem] leading-[1.75] text-offwhite/85 opacity-0"
    >
      I am Antarik and I am merging design, technology, and storytelling into
      digital experiences with intentional tension and cinematic precision.
    </p>

    <div class="hero-copy mt-6 flex flex-wrap gap-3 opacity-0">
      <Button href="/work">→ View Work</Button>
      <Button href="#about" variant="ghost">↓ About</Button>
    </div>

    <div
      class="hero-scroll pointer-events-none absolute bottom-8 right-4 flex flex-col items-center gap-2 font-necto text-[0.62rem] uppercase tracking-[0.3em] text-teal md:right-8"
    >
      <span class="[writing-mode:vertical-rl]">Scroll</span>
      <span class="animate-bounce">↓</span>
    </div>
  </div>
</section>

<script>
  function initHero() {
    const lines = document.querySelectorAll<HTMLElement>(".hero-line");
    if (!lines.length) return;

    const copy = document.querySelectorAll<HTMLElement>(".hero-copy");
    const scrollPrompt = document.querySelector<HTMLElement>(".hero-scroll");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    window.addEventListener("scroll", () => {
      if (!scrollPrompt) return;
      scrollPrompt.classList.toggle("opacity-0", window.scrollY > 100);
    }, { passive: true });

    if (reduceMotion) {
      lines.forEach((line) => { line.style.clipPath = "inset(0% 0 0 0)"; });
      copy.forEach((item) => { item.style.opacity = "1"; });
      return;
    }

    const GLITCH = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%+-=";
    const DECODE_MS = 1600;
    const STAGGER_MS = 350;
    const CYCLE_INTERVAL = 45; // ~22Hz per character — smooth, intentional cycling

    const originals = Array.from(lines).map((line) => line.textContent ?? "");

    // Initial scramble before clip-path reveal
    lines.forEach((line, i) => {
      line.textContent = originals[i]
        .split("")
        .map((ch) => (ch === " " ? " " : GLITCH[Math.floor(Math.random() * GLITCH.length)]))
        .join("");
      line.style.clipPath = "inset(0% 0 0 0)";
    });

    const t0 = performance.now();
    const lineStarts = originals.map((_, i) => t0 + i * STAGGER_MS);

    // Per-character settle timestamps with organic jitter (±10% of DECODE_MS)
    const settleAt = originals.map((orig, li) =>
      orig.split("").map((ch, j) => {
        if (ch === " ") return 0;
        const base = lineStarts[li] + (j / Math.max(orig.length - 1, 1)) * DECODE_MS;
        const jitter = (Math.random() - 0.5) * DECODE_MS * 0.18;
        return base + jitter;
      })
    );

    // Cached glyphs — each char holds its current scramble value between ticks
    const currentChars = originals.map((orig) =>
      orig.split("").map((ch) =>
        ch === " " ? " " : GLITCH[Math.floor(Math.random() * GLITCH.length)]
      )
    );

    // Last cycle timestamp per character
    const lastCycle = originals.map((orig) => orig.split("").map(() => 0));

    let done = false;

    function frame(now: number) {
      if (done) return;
      let allComplete = true;

      lines.forEach((line, i) => {
        const orig = originals[i];
        let lineComplete = true;

        const chars = orig.split("").map((ch, j) => {
          if (ch === " ") return " ";
          if (now >= settleAt[i][j]) {
            currentChars[i][j] = ch;
            return ch;
          }
          lineComplete = false;
          allComplete = false;
          // Throttle: only pick a new glyph every CYCLE_INTERVAL ms
          if (now - lastCycle[i][j] >= CYCLE_INTERVAL) {
            lastCycle[i][j] = now;
            currentChars[i][j] = GLITCH[Math.floor(Math.random() * GLITCH.length)];
          }
          return currentChars[i][j];
        });

        line.textContent = chars.join("");
      });

      if (allComplete) {
        done = true;
        lines.forEach((line, i) => { line.textContent = originals[i]; });
        copy.forEach((item) => {
          item.style.transition = "opacity 0.5s ease";
          item.style.opacity = "1";
        });
      } else {
        requestAnimationFrame(frame);
      }
    }

    requestAnimationFrame(frame);
  }

  document.addEventListener("astro:page-load", initHero);

  // Smooth scroll for anchor links within the hero
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        const target = document.querySelector(anchor.getAttribute("href")!);
        if (!target) return;
        e.preventDefault();
        const start = window.scrollY;
        const end = (target as HTMLElement).getBoundingClientRect().top + start;
        const duration = 1100; // ms
        const t0 = performance.now();
        (function step(now: number) {
          const elapsed = now - t0;
          const progress = Math.min(elapsed / duration, 1);
          // ease-in-out cubic
          const ease = progress < 0.5
            ? 4 * progress * progress * progress
            : 1 - Math.pow(-2 * progress + 2, 3) / 2;
          window.scrollTo(0, start + (end - start) * ease);
          if (progress < 1) requestAnimationFrame(step);
        })(t0);
      });
    });
  });
</script>
