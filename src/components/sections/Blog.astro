---
import SectionLabel from '../ui/SectionLabel.astro';

const posts = [
  {
    title: 'Building Cinematic UX in Astro',
    date: '2026-02-12',
    readTime: '6 min',
    excerpt: 'How motion pacing, asymmetry, and layout density create narrative rhythm in product interfaces.',
    href: '/blog/cinematic-ux-astro'
  },
  {
    title: 'Wireframe Bodies & Data Wires',
    date: '2026-02-03',
    readTime: '8 min',
    excerpt: 'Designing a Ghost in the Shell inspired hero scene with Three.js while keeping performance grounded.',
    href: '/blog/wireframe-bodies-data-wires'
  }
];
---

<section class="border-b border-grey px-4 py-24 md:px-8" id="blog">
  <div class="mx-auto w-full max-w-7xl">
    <SectionLabel label="Blog" />
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {posts.map((post) => (
        <article class="border border-grey p-6 transition hover:border-teal hover:bg-surface" data-cursor-hover>
          <p class="font-necto text-[0.72rem] uppercase tracking-[0.22em] text-teal">{post.date} · {post.readTime}</p>
          <h3 class="mt-3 font-serif text-[2rem] leading-[1.1]">{post.title}</h3>
          <p class="mt-3 line-clamp-2 text-[1rem] leading-[1.6] text-offwhite/80">{post.excerpt}</p>
          <a class="mt-4 inline-block font-montserrat text-[0.7rem] uppercase tracking-[0.22em] text-offwhite/90" href={post.href}>
            Read Post →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

