---
interface Props {
  href?: string;
  variant?: 'primary' | 'ghost';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
}

const {
  href,
  variant = 'primary',
  class: className = '',
  type = 'button'
} = Astro.props;

const base =
  'inline-flex items-center gap-3 font-necto font-bold text-[0.8rem] uppercase tracking-[0.18em] px-8 py-4 transition-all duration-300';
const style =
  variant === 'primary'
    ? 'bg-teal text-black hover:bg-offwhite [background-image:linear-gradient(135deg,rgba(255,255,255,0.18)_0%,transparent_50%,rgba(0,0,0,0.08)_100%)]'
    : 'border border-offwhite/60 text-offwhite hover:border-teal hover:text-teal';
---

{
  href ? (
    <a href={href} class={`${base} ${style} ${className}`} data-cursor-hover>
      <slot />
    </a>
  ) : (
    <button type={type} class={`${base} ${style} ${className}`} data-cursor-hover>
      <slot />
    </button>
  )
}

