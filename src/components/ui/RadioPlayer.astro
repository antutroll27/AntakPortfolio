---
---

<div class="radio-player bg-[#FAA500] border border-black/[0.12]" data-radio-widget>

  <!-- Top bar: station name (left) + active genre badge (right) -->
  <div class="flex items-center justify-between border-b border-black/[0.12] px-3.5 py-2.5">
    <span class="font-necto text-[0.75rem] text-black/85 truncate pr-2" data-radio-station>Nightwave Plaza</span>
    <span class="flex-shrink-0 bg-black/[0.12] px-1.5 py-0.5 font-montserrat text-[0.45rem] uppercase tracking-[0.12em] text-black/70" data-genre-badge>Synth</span>
  </div>

  <!-- Tape reel SVG area -->
  <div class="relative px-3 pt-3 pb-1" data-tape-area>
    <svg viewBox="0 0 242 130" xmlns="http://www.w3.org/2000/svg" class="w-full">

      <!-- LEFT REEL at (65, 62) -->
      <circle cx="65" cy="62" r="42" fill="rgba(0,0,0,0.05)" stroke="rgba(0,0,0,0.18)" stroke-width="1"/>
      <circle cx="65" cy="62" r="34" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="0.5"/>
      <circle cx="65" cy="62" r="25" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="0.5"/>
      <g data-reel="left" transform="translate(65,62)">
        <line x1="0" y1="-12" x2="0" y2="12"      stroke="rgba(0,0,0,0.55)" stroke-width="1.2"/>
        <line x1="-10.4" y1="-6" x2="10.4" y2="6" stroke="rgba(0,0,0,0.55)" stroke-width="1.2"/>
        <line x1="-10.4" y1="6"  x2="10.4" y2="-6" stroke="rgba(0,0,0,0.55)" stroke-width="1.2"/>
        <circle cx="0" cy="0" r="9" fill="#8B6200" stroke="rgba(0,0,0,0.40)" stroke-width="1"/>
        <circle cx="0" cy="0" r="2.5" fill="rgba(0,0,0,0.70)"/>
      </g>

      <!-- RIGHT REEL at (177, 62) -->
      <circle cx="177" cy="62" r="42" fill="rgba(0,0,0,0.05)" stroke="rgba(0,0,0,0.18)" stroke-width="1"/>
      <circle cx="177" cy="62" r="34" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="0.5"/>
      <circle cx="177" cy="62" r="25" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="0.5"/>
      <g data-reel="right" transform="translate(177,62)">
        <line x1="0" y1="-12" x2="0" y2="12"      stroke="rgba(0,0,0,0.55)" stroke-width="1.2"/>
        <line x1="-10.4" y1="-6" x2="10.4" y2="6" stroke="rgba(0,0,0,0.55)" stroke-width="1.2"/>
        <line x1="-10.4" y1="6"  x2="10.4" y2="-6" stroke="rgba(0,0,0,0.55)" stroke-width="1.2"/>
        <circle cx="0" cy="0" r="9" fill="#8B6200" stroke="rgba(0,0,0,0.40)" stroke-width="1"/>
        <circle cx="0" cy="0" r="2.5" fill="rgba(0,0,0,0.70)"/>
      </g>

      <!-- UPPER TAPE: Λ shape -->
      <circle cx="90"  cy="36" r="3"   fill="#8B6200" stroke="rgba(0,0,0,0.35)" stroke-width="0.8"/>
      <circle cx="152" cy="36" r="3"   fill="#8B6200" stroke="rgba(0,0,0,0.35)" stroke-width="0.8"/>
      <circle cx="121" cy="26" r="3.5" fill="#8B6200" stroke="rgba(0,0,0,0.40)" stroke-width="0.9"/>
      <path data-tape-path-top d="M 90 36 L 121 26 L 152 36" fill="none" stroke="rgba(0,0,0,0.55)" stroke-width="1.3"/>

      <!-- LOWER TAPE: V past playback head -->
      <path data-tape-path d="M 88 106 L 121 118 L 154 106" fill="none" stroke="rgba(0,0,0,0.55)" stroke-width="1.5"/>

      <!-- Playback head marker -->
      <rect x="118.5" y="110" width="5" height="11" rx="0.5" fill="rgba(0,0,0,0.75)"/>

      <!-- Decorative label -->
      <text x="121" y="129" text-anchor="middle" font-family="NectoMono, monospace" font-size="7" fill="rgba(0,0,0,0.25)" letter-spacing="2">TAPE</text>

    </svg>
  </div>

  <!-- Genre tab row -->
  <div class="flex border-t border-b border-black/[0.12]">
    <button class="radio-tab flex-1 py-1.5 font-montserrat text-[0.46rem] uppercase tracking-[0.12em] text-black bg-black/[0.10] transition-all duration-150" data-genre="synth" data-cursor-hover>Synth</button>
    <button class="radio-tab flex-1 py-1.5 font-montserrat text-[0.46rem] uppercase tracking-[0.12em] text-black/40 hover:text-black/70 transition-all duration-150" data-genre="jazz" data-cursor-hover>Jazz</button>
    <button class="radio-tab flex-1 py-1.5 font-montserrat text-[0.46rem] uppercase tracking-[0.12em] text-black/40 hover:text-black/70 transition-all duration-150" data-genre="afro" data-cursor-hover>Afro</button>
    <button class="radio-tab flex-1 py-1.5 font-montserrat text-[0.46rem] uppercase tracking-[0.12em] text-black/40 hover:text-black/70 transition-all duration-150" data-genre="pop" data-cursor-hover>Pop</button>
  </div>

  <!-- Controls row -->
  <div class="flex items-center gap-2.5 border-t border-black/[0.12] px-3.5 py-2.5">

    <!-- Play / Pause -->
    <button
      class="flex h-9 w-9 flex-shrink-0 items-center justify-center bg-black text-[#FAA500] transition-opacity hover:opacity-75"
      data-radio-play
      data-cursor-hover
      aria-label="Play / Pause"
    >
      <span data-radio-play-icon class="text-[0.75rem] leading-none">&#9654;</span>
    </button>

    <!-- Next station -->
    <button
      class="flex-1 text-left font-montserrat text-[0.48rem] uppercase tracking-[0.15em] text-black/50 transition-colors hover:text-black"
      data-radio-next
      data-cursor-hover
    >Next &#8594;</button>

    <!-- Volume -->
    <input
      type="range"
      class="radio-vol w-14 cursor-pointer"
      min="0" max="1" step="0.05" value="0.7"
      data-radio-volume
      aria-label="Volume"
    />

  </div>

</div>

<style>
  /* Tape path scrolling dashes */
  @keyframes tape-flow     { to { stroke-dashoffset: -9; } }
  @keyframes tape-flow-rev { to { stroke-dashoffset:  9; } }

  [data-tape-path-top].tape-moving {
    stroke-dasharray: 5 4;
    animation: tape-flow 0.35s linear infinite;
  }

  [data-tape-path].tape-moving {
    stroke-dasharray: 5 4;
    animation: tape-flow-rev 0.35s linear infinite;
  }

  /* Volume slider */
  .radio-vol {
    -webkit-appearance: none;
    appearance: none;
    height: 2px;
    background: rgba(0, 0, 0, 0.20);
    border-radius: 0;
    outline: none;
  }
  .radio-vol::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 8px;
    height: 8px;
    background: rgba(0,0,0,0.75);
    cursor: pointer;
  }
  .radio-vol::-moz-range-thumb {
    width: 8px;
    height: 8px;
    background: rgba(0,0,0,0.75);
    border: none;
    cursor: pointer;
  }
</style>

<script>
  type Station = { name: string; url: string; desc: string };
  type Stations = Record<string, Station[]>;

  const STATIONS: Stations = {
    synth: [
      { name: 'Nightwave Plaza',  url: 'https://radio.plaza.one/mp3',               desc: 'Vaporwave · Synthwave' },
      { name: 'SomaFM Synphaera', url: 'https://ice1.somafm.com/synphaera-128-mp3', desc: 'Space Synth · Ambient Electronic' },
      { name: 'SomaFM Digitalis', url: 'https://ice1.somafm.com/digitalis-128-mp3', desc: 'Synth-Pop · Modular · Electronic' },
    ],
    jazz: [
      { name: 'Jazz24',           url: 'https://live.amperwave.net/direct/ppm-jazz24mp3-ibc1', desc: 'Contemporary Jazz · KNKX' },
      { name: 'WBGO 88.3 FM',     url: 'https://ais-sa8.cdnstream1.com/3629_128.mp3',          desc: 'Jazz · Newark NJ' },
      { name: 'WWOZ New Orleans', url: 'https://wwoz-sc.streamguys.com/wwoz-hi.mp3',            desc: 'New Orleans Jazz · Blues · R&B' },
    ],
    afro: [
      { name: 'Afrobeats Radio',  url: 'https://stream.zeno.fm/y4wvz9sf4nhvv',        desc: 'Afrobeats · Afropop · Contemporary' },
      { name: 'WHFF Afrobeats',   url: 'https://azuracast.whff.radio:8120/radio.mp3', desc: 'Afrobeats · Dancehall · Naija' },
      { name: 'SomaFM Dub Step',  url: 'https://ice5.somafm.com/dubstep-128-mp3',     desc: 'Bass · Electronic · Beats' },
    ],
    pop: [
      { name: 'KEXP 90.3',              url: 'https://kexp-mp3-128.streamguys1.com/kexp128.mp3', desc: 'Indie · Alternative · Seattle' },
      { name: 'SomaFM Indie Pop Rocks', url: 'https://ice5.somafm.com/indiepop-128-mp3',         desc: 'Indie Pop · Jangle Pop' },
      { name: 'SomaFM Lush',           url: 'https://ice5.somafm.com/lush-128-mp3',              desc: 'Shoegaze · Dreampop · Indie' },
    ],
  };

  function initRadio() {
    const widget = document.querySelector<HTMLElement>('[data-radio-widget]');
    if (!widget) return;

    const audio       = new Audio();
    audio.volume      = 0.7;
    audio.preload     = 'none';
    // crossOrigin intentionally omitted — radio streams don't set CORS headers

    let genre   = 'synth';
    let idx     = 0;
    let playing = false;

    let pendingPlay: Promise<void> | null = null;
    let retryCount = 0;

    // Reel RAF animation
    let rafId: number | null = null;
    let leftAngle  = 0;
    let rightAngle = 0;
    let lastTime   = 0;

    const stationEl  = widget.querySelector<HTMLElement>('[data-radio-station]');
    const badgeEl    = widget.querySelector<HTMLElement>('[data-genre-badge]');
    const playBtn    = widget.querySelector<HTMLElement>('[data-radio-play]');
    const playIcon   = widget.querySelector<HTMLElement>('[data-radio-play-icon]');
    const nextBtn    = widget.querySelector<HTMLElement>('[data-radio-next]');
    const volEl      = widget.querySelector<HTMLInputElement>('[data-radio-volume]');
    const tabs       = widget.querySelectorAll<HTMLElement>('[data-genre]');
    const leftReel   = widget.querySelector<SVGGElement>('[data-reel="left"]');
    const rightReel  = widget.querySelector<SVGGElement>('[data-reel="right"]');
    const tapePath    = widget.querySelector<SVGPathElement>('[data-tape-path]');
    const tapePathTop = widget.querySelector<SVGPathElement>('[data-tape-path-top]');

    function animateReels(time: number) {
      const dt = lastTime ? (time - lastTime) / 1000 : 0;
      lastTime = time;
      leftAngle  = (leftAngle  + dt * 180)   % 360; // 2 s / rotation
      rightAngle = (rightAngle + dt * 156.5) % 360; // 2.3 s / rotation
      leftReel?.setAttribute('transform',  `translate(65,62) rotate(${leftAngle})`);
      rightReel?.setAttribute('transform', `translate(177,62) rotate(${rightAngle})`);
      rafId = requestAnimationFrame(animateReels);
    }

    function startReels() {
      if (rafId) return;
      lastTime = 0;
      rafId = requestAnimationFrame(animateReels);
    }

    function stopReels() {
      if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    }

    function current(): Station {
      return STATIONS[genre][idx];
    }

    function renderInfo() {
      const s = current();
      if (stationEl) stationEl.textContent = s.name;
      if (badgeEl)   badgeEl.textContent = genre === 'afro' ? 'Afro' : genre.charAt(0).toUpperCase() + genre.slice(1);
    }

    function setPlayState(state: boolean) {
      playing = state;
      if (playIcon) playIcon.innerHTML = state ? '&#9632;' : '&#9654;';
      if (state) startReels(); else stopReels();
      tapePath?.classList.toggle('tape-moving', state);
      tapePathTop?.classList.toggle('tape-moving', state);
    }

    function loadPlay() {
      audio.pause();
      audio.src = '';
      audio.src = current().url;
      audio.load();

      pendingPlay = audio.play();
      pendingPlay
        .then(() => {
          pendingPlay = null;
          setPlayState(true);
        })
        .catch((err: Error) => {
          pendingPlay = null;
          if (err.name === 'AbortError') return;
          nextStation();
        });
    }

    function nextStation() {
      const list = STATIONS[genre];
      retryCount++;
      if (retryCount >= list.length) {
        retryCount = 0;
        setPlayState(false);
        return;
      }
      idx = (idx + 1) % list.length;
      renderInfo();
      if (playing) loadPlay();
    }

    function switchGenre(g: string) {
      retryCount = 0;
      genre = g;
      idx = 0;
      renderInfo();
      tabs.forEach(tab => {
        const active = tab.dataset.genre === g;
        tab.classList.toggle('text-black',     active);
        tab.classList.toggle('bg-black/[0.10]', active);
        tab.classList.toggle('text-black/40',  !active);
      });
      if (playing) loadPlay();
    }

    // Event listeners
    playBtn?.addEventListener('click', () => {
      if (playing) { audio.pause(); setPlayState(false); }
      else loadPlay();
    });

    nextBtn?.addEventListener('click', nextStation);

    volEl?.addEventListener('input', () => {
      audio.volume = parseFloat(volEl.value);
    });

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const g = tab.dataset.genre;
        if (g && g !== genre) switchGenre(g);
      });
    });

    audio.addEventListener('error', () => {
      if (playing || pendingPlay) nextStation();
    });
    audio.addEventListener('ended', () => setPlayState(false));

    renderInfo();

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      stopReels();
      pendingPlay = null;
      audio.pause();
      audio.src = '';
      audio.load();
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initRadio);
</script>
