<div class="absolute inset-0" data-ghost-scene></div>

<script>
  import * as THREE from 'three';

  let renderer: THREE.WebGLRenderer | null = null;
  let rafId: number | null = null;

  function initGhostScene() {
    const host = document.querySelector('[data-ghost-scene]');
    if (!host) return; // not on hero page

    // Clean up previous instance if navigating back
    if (renderer) {
      renderer.dispose();
      renderer = null;
    }
    if (rafId) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }
    // Clear any existing canvas
    host.innerHTML = '';

    const scene = new THREE.Scene();
    scene.background = new THREE.Color('#0A0C10');

    const camera = new THREE.PerspectiveCamera(50, host.clientWidth / host.clientHeight, 0.1, 100);
    camera.position.set(0, 0.4, 4.8);

    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.setSize(host.clientWidth, host.clientHeight);
    host.appendChild(renderer.domElement);

    const ambientLight = new THREE.AmbientLight('#0D1520', 0.4);
    scene.add(ambientLight);
    const centerLight = new THREE.PointLight('#2CB8B0', 0.8, 8);
    centerLight.position.set(0, 0.5, 1.8);
    scene.add(centerLight);
    const rimLight = new THREE.PointLight('#7EB8D4', 0.5, 8);
    rimLight.position.set(2, 2, 2);
    scene.add(rimLight);

    const makeFigure = (color: THREE.ColorRepresentation, x: number, z: number) => {
      const group = new THREE.Group();
      const body = new THREE.CapsuleGeometry(0.22, 1.1, 4, 8);
      const head = new THREE.SphereGeometry(0.2, 8, 8);

      const bodyWire = new THREE.LineSegments(new THREE.WireframeGeometry(body), new THREE.LineBasicMaterial({ color }));
      const headWire = new THREE.LineSegments(new THREE.WireframeGeometry(head), new THREE.LineBasicMaterial({ color }));
      headWire.position.y = 0.9;

      group.add(bodyWire);
      group.add(headWire);
      group.position.set(x, 0, z);
      scene.add(group);
      return group;
    };

    const figureA = makeFigure('#7EB8D4', -0.8, 0);
    const figureB = makeFigure('#4A90C4', 0.8, -0.25);

    const cableMaterial = new THREE.LineBasicMaterial({ color: '#ffffff', transparent: true, opacity: 0.45 });
    const cables: { line: THREE.Line; points: THREE.Vector3[]; offset: number }[] = [];
    const isSmallViewport = window.innerWidth < 768;
    const lowCpu = typeof navigator.hardwareConcurrency === 'number' && navigator.hardwareConcurrency <= 4;
    // @ts-ignore: navigator.connection is non-standard
    const saveData = Boolean(navigator.connection && 'saveData' in navigator.connection && navigator.connection.saveData);
    const lowCapability = isSmallViewport || lowCpu || saveData;
    const cableCount = lowCapability ? 3 : 6;
    const cableSegments = lowCapability ? 24 : 40;
    const radialCount = lowCapability ? 14 : 24;

    for (let i = 0; i < cableCount; i += 1) {
      const points = Array.from({ length: 5 }, (_, idx) => {
        const t = idx / 4;
        return new THREE.Vector3(-0.8 + t * 1.6, Math.sin(t * Math.PI) * (0.4 + Math.random() * 0.3), -0.3 + Math.random() * 0.8);
      });
      const curve = new THREE.CatmullRomCurve3(points);
      const geometry = new THREE.BufferGeometry().setFromPoints(curve.getPoints(cableSegments));
      const line = new THREE.Line(geometry, cableMaterial.clone());
      scene.add(line);
      cables.push({ line, points, offset: Math.random() * Math.PI * 2 });
    }

    const ring = new THREE.Mesh(
      new THREE.RingGeometry(0.48, 0.55, 48),
      new THREE.MeshBasicMaterial({ color: '#2CB8B0', transparent: true, opacity: 0.08, side: THREE.DoubleSide })
    );
    ring.position.set(-0.8, 0.5, -0.35);
    scene.add(ring);

    const radialGroup = new THREE.Group();
    for (let i = 0; i < radialCount; i += 1) {
      const angle = (i / radialCount) * Math.PI * 2;
      const points = [
        new THREE.Vector3(Math.cos(angle) * 0.45, Math.sin(angle) * 0.45, -0.5),
        new THREE.Vector3(Math.cos(angle) * 2.6, Math.sin(angle) * 2.6, -1.2)
      ];
      const geometry = new THREE.BufferGeometry().setFromPoints(points);
      const material = new THREE.LineBasicMaterial({ color: '#AACCDD', transparent: true, opacity: 0.15 });
      const line = new THREE.Line(geometry, material);
      radialGroup.add(line);
    }
    scene.add(radialGroup);

    const pointer = { x: 0, y: 0 };
    window.addEventListener('pointermove', (event) => {
      pointer.x = (event.clientX / window.innerWidth) * 2 - 1;
      pointer.y = (event.clientY / window.innerHeight) * 2 - 1;
    });

    const handleResize = () => {
      if (!renderer) return;
      camera.aspect = host.clientWidth / host.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(host.clientWidth, host.clientHeight);
    };
    window.addEventListener('resize', handleResize);

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const start = performance.now();
    let active = !document.hidden;

    document.addEventListener('visibilitychange', () => {
      active = !document.hidden;
    });

    const animate = (now: number) => {
      if (!renderer) return; // disposed — stop loop
      rafId = requestAnimationFrame(animate);

      if (!active) return;

      const time = (now - start) * 0.001;

      if (!reduceMotion) {
        figureA.rotation.y = time / 30;
        figureB.rotation.y = -time / 30;
        camera.position.x += (pointer.x * 0.11 - camera.position.x) * 0.025;
        camera.position.y += (-pointer.y * 0.05 - camera.position.y + 0.4) * 0.025;

        if (!lowCapability) {
          cables.forEach((cable) => {
            const animatedPoints = cable.points.map((point: THREE.Vector3, index: number) => {
              const clone = point.clone();
              clone.y += Math.sin(time + cable.offset + index * 0.7) * 0.03;
              clone.z += Math.cos(time + cable.offset + index * 0.6) * 0.025;
              return clone;
            });
            const curve = new THREE.CatmullRomCurve3(animatedPoints);
            cable.line.geometry.setFromPoints(curve.getPoints(cableSegments));
            (cable.line.material as THREE.LineBasicMaterial).opacity = 0.45 + Math.sin(time + cable.offset) * 0.15;
          });
        }

        if (!lowCapability) {
          radialGroup.children.forEach((line, index) => {
            ((line as THREE.Line).material as THREE.LineBasicMaterial).opacity = 0.12 + (Math.sin(time * 0.7 + index * 0.2) + 1) * 0.03;
          });
        }
      }

      renderer.render(scene, camera);
    };

    rafId = requestAnimationFrame(animate);
  }

  document.addEventListener('astro:page-load', initGhostScene);
</script>
